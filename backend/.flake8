[flake8]
max-line-length = 119
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    */migrations/*,
    venv,
    .venv,
    env,
    .env,

per-file-ignores =
    # Ignore "star import" and "undefined names" errors only in the settings folder
    vulgpt/settings/*.py: F401, F403, F405